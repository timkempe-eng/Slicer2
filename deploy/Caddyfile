# Reverse proxy for SlicedBambu.
#
# The named site gets an automatic Let's Encrypt certificate and serves HTTPS as
# soon as slicedbambu.com's DNS A record points at this droplet. The :80 catch-all
# keeps plain-HTTP access working in the meantime (e.g. the droplet IP, and the
# domain before its cert is issued), so there's no downtime during the DNS cutover.

# Shared hardening headers. The CSP is scoped to what the page actually loads
# (self + Google AdSense + the Stripe donate link); tighten if those change.
(hardening) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), usb=()"
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https:; font-src 'self' data: https:; style-src 'self' 'unsafe-inline' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://pagead2.googlesyndication.com https://*.googlesyndication.com https://*.googleadservices.com https://*.googletagservices.com https://*.google.com https://*.gstatic.com https://*.doubleclick.net https://adservice.google.com https://*.adtrafficquality.google; frame-src https://*.googlesyndication.com https://*.doubleclick.net https://*.google.com https://*.adtrafficquality.google; connect-src 'self' https:; form-action 'self' https://buy.stripe.com"
		-Server
	}
}

slicedbambu.com, www.slicedbambu.com {
	import hardening
	reverse_proxy app:8000

	# Allow large model uploads.
	request_body {
		max_size 250MB
	}

	encode zstd gzip
}

:80 {
	import hardening
	reverse_proxy app:8000

	request_body {
		max_size 250MB
	}

	encode zstd gzip
}
